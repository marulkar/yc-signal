rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: startups
    // Fields:
    //   - name: string (required)
    //   - batch: string (required)
    //   - signalScore: number (required)
    //   - description: string
    //   - website: string (url)
    //   - ycUrl: string (url)
    //   - founders: list of maps
    //   - moatAnalysis: string
    //   - sentiment: number
    //   - founderPedigreeScore: number
    //   - technicalMoatScore: number
    //   - hypeCoefficient: number
    //   - hnCommentsCount: int
    //   - githubStars: int
    //   - updatedAt: timestamp
    //
    // Collection: users
    // Fields:
    //   - email: string (required)
    //   - role: string (required, ['admin', 'user'])
    //   - watchlist: list of strings
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "champsam365@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidStartup(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.batch is string && data.batch.size() > 0 &&
             data.signalScore is number &&
             (!('description' in data) || (data.description is string && data.description.size() < 2000)) &&
             (!('website' in data) || (data.website is string && data.website.size() < 500)) &&
             (!('ycUrl' in data) || (data.ycUrl is string && data.ycUrl.size() < 500));
    }

    function isValidUser(data) {
      return data.email is string && data.email.size() > 0 &&
             data.role in ['admin', 'user'] &&
             (!('watchlist' in data) || data.watchlist is list);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /startups/{startupId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidStartup(request.resource.data);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    ((isOwner(userId) && request.resource.data.role == 'user') || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    ((isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin());
    }
  }
}
